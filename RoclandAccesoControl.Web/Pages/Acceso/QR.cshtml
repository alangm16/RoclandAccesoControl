@page "/Acceso/QR"
@model RoclandAccesoControl.Web.Pages.Acceso.QRModel
@{
    ViewData["Title"] = "Código QR — Acceso";
    Layout = "~/Pages/Shared/_AccesoLayout.cshtml";
}

@section Styles {
<style>
    .qr-page { text-align: center; padding: 1.5rem 0; }

    .qr-container {
        display: inline-block;
        background: white;
        border: 3px solid var(--rocland-black);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
        box-shadow: 0 8px 32px rgba(0,0,0,0.15);
        margin-bottom: 1.25rem;
    }

    .qr-container img { display: block; width: 220px; height: 220px; }

    .qr-label {
        font-family: var(--font-display);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--rocland-gray);
        margin-top: 0.75rem;
    }

    .qr-url {
        font-size: 0.75rem;
        color: var(--rocland-gray);
        word-break: break-all;
        background: var(--rocland-light);
        border: 1px solid var(--rocland-border);
        border-radius: var(--radius-md);
        padding: 0.55rem 0.85rem;
        margin: 0.5rem auto 1.25rem;
        max-width: 420px;
        font-family: monospace;
    }

    .btn-print {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        background: var(--rocland-black);
        color: white;
        font-family: var(--font-display);
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border: none;
        border-radius: var(--radius-md);
        padding: 0.7rem 1.5rem;
        cursor: pointer;
        margin: 0 0.4rem 0.75rem;
        text-decoration: none;
        transition: background 0.2s;
    }

    .btn-print:hover { background: var(--rocland-dark); color: white; }

    .btn-print-green { background: var(--rocland-green); }
    .btn-print-green:hover { background: var(--rocland-green-dark); }

    @@media print {
        .acceso-header, .acceso-footer, .btn-print, .qr-url, .no-print { display: none !important; }
        .qr-container { border-color: #000; box-shadow: none; }
    }
</style>
}

<div class="qr-page fade-in">

    <div class="form-page-tag mb-3">
        <i class="bi bi-qr-code"></i> Código QR de Acceso
    </div>

    <h1 class="form-page-title mb-1">QR para Caseta</h1>
    <p class="selector-subtitle mb-3">
        Escanea este código o imprímelo para instalarlo en la caseta de seguridad.
    </p>

    <!-- ── QR Image ───────────────────────────────────────────── -->
    <div class="qr-container">
        <img id="qrImg"
             src="/api/qr/generar"
             alt="Código QR de acceso"
             onerror="this.style.display='none'; document.getElementById('qrError').style.display='block'" />
        <div id="qrError" style="display:none; width:220px; height:220px; display:none;
             align-items:center; justify-content:center; color:var(--rocland-danger); font-size:0.85rem;">
            <i class="bi bi-exclamation-circle me-1"></i> Error cargando QR
        </div>
        <div class="qr-label">Rocland — Control de Acceso</div>
    </div>

    <!-- ── URL ────────────────────────────────────────────────── -->
    <div class="qr-url" id="qrUrl">Cargando URL...</div>

    <!-- ── Acciones ───────────────────────────────────────────── -->
    <div class="no-print">
        <button class="btn-print btn-print-green" onclick="window.print()">
            <i class="bi bi-printer-fill"></i> Imprimir QR
        </button>
        <a class="btn-print" id="btnDescarga" href="/api/qr/generar" download="rocland-acceso-qr.png">
            <i class="bi bi-download"></i> Descargar PNG
        </a>
    </div>

    <p class="selector-note no-print" style="max-width:460px; margin: 0 auto;">
        <i class="bi bi-lightbulb me-1"></i>
        <strong>Tip:</strong> Imprime este QR en tamaño carta o A4, plástifícalo
        y colócalo en un lugar visible de la caseta de seguridad.
    </p>

</div>

@section Scripts {
<script>
    // Cargar URL del formulario
    fetch('/api/qr/url')
        .then(r => r.json())
        .then(data => {
            document.getElementById('qrUrl').textContent = data.url;
            document.getElementById('btnDescarga').href =
                `/api/qr/generar?url=${encodeURIComponent(data.url)}`;
        })
        .catch(() => {
            document.getElementById('qrUrl').textContent = window.location.origin + '/Acceso';
        });
</script>
}
