<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RoclandAccesoControl.Mobile.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RoclandAccesoControl.Mobile.ViewModels"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F172A">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0"
                             VerticalOptions="Center">

            <!-- Logo / Marca -->
            <Frame BackgroundColor="#1E293B" CornerRadius="20"
                   Padding="24" Margin="0,0,0,40"
                   BorderColor="Transparent" HorizontalOptions="Center">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="🛡" FontSize="52" HorizontalOptions="Center"/>
                    <Label Text="ROCLAND" FontSize="22" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center"
                           CharacterSpacing="4"/>
                    <Label Text="Control de Acceso" FontSize="13"
                           TextColor="#94A3B8" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Tarjeta de login -->
            <Frame BackgroundColor="#1E293B" CornerRadius="16"
                   Padding="24" BorderColor="#334155">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Iniciar sesión" FontSize="20"
                           FontAttributes="Bold" TextColor="White"/>

                    <!-- Usuario -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Usuario" FontSize="13" TextColor="#94A3B8"/>
                        <Frame BackgroundColor="#0F172A" CornerRadius="10"
                               Padding="0" BorderColor="#334155">
                            <Entry Placeholder="Usuario de guardia"
                                   PlaceholderColor="#475569"
                                   TextColor="White"
                                   Text="{Binding Usuario}"
                                   Margin="12,0"
                                   HeightRequest="48"
                                   Keyboard="Text"
                                   ReturnType="Next"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Contraseña -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Contraseña" FontSize="13" TextColor="#94A3B8"/>
                        <Frame BackgroundColor="#0F172A" CornerRadius="10"
                               Padding="0" BorderColor="#334155">
                            <Entry Placeholder="Contraseña"
                                   PlaceholderColor="#475569"
                                   TextColor="White"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   Margin="12,0"
                                   HeightRequest="48"
                                   ReturnType="Go"
                                   ReturnCommand="{Binding IniciarSesionCommand}"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Error -->
                    <Frame BackgroundColor="#450A0A" CornerRadius="8"
                           Padding="12" BorderColor="#B91C1C"
                           IsVisible="{Binding HayError}">
                        <Label Text="{Binding MensajeError}" TextColor="#FCA5A5"
                               FontSize="13"/>
                    </Frame>

                    <!-- Botón -->
                    <Button Text="Ingresar"
                            Command="{Binding IniciarSesionCommand}"
                            BackgroundColor="#2563EB"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="52"
                            FontSize="16"/>

                    <!-- Loading -->
                    <ActivityIndicator IsRunning="{Binding EstaCargando}"
                                       IsVisible="{Binding EstaCargando}"
                                       Color="#2563EB"
                                       HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="v1.0 · Rocland © 2025"
                   FontSize="11" TextColor="#334155"
                   HorizontalOptions="Center" Margin="0,24,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>