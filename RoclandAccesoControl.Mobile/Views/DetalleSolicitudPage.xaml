<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RoclandAccesoControl.Mobile.Views.DetalleSolicitudPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RoclandAccesoControl.Mobile.ViewModels"
             x:DataType="vm:DetalleSolicitudViewModel"
             Title="Detalle de solicitud"
             BackgroundColor="#0F172A">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding EstaCargando}"
                               IsVisible="{Binding EstaCargando}"
                               Color="#2563EB" HeightRequest="50"/>

            <!-- Card principal -->
            <Frame BackgroundColor="#1E293B" CornerRadius="16"
                   Padding="20" BorderColor="#334155"
                   IsVisible="{Binding NoEstaCargando}">
                <VerticalStackLayout Spacing="16">

                    <!-- Encabezado: icono + nombre -->
                    <HorizontalStackLayout Spacing="14">
                        <Frame BackgroundColor="#0F172A" CornerRadius="12"
                               Padding="14" BorderColor="Transparent">
                            <Label Text="{Binding Solicitud.TipoIcono}" FontSize="30"/>
                        </Frame>
                        <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding Solicitud.NombrePersona}"
                                   FontSize="20" FontAttributes="Bold" TextColor="White"/>
                            <Frame BackgroundColor="{Binding Solicitud.TipoColor}"
                                   CornerRadius="6" Padding="8,3" BorderColor="Transparent">
                                <Label Text="{Binding Solicitud.TipoRegistro}"
                                       FontSize="12" TextColor="White"/>
                            </Frame>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1" Color="#334155"/>

                    <!-- Datos -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                        <!-- ID -->
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="3">
                            <Label Text="Identificación" FontSize="11" TextColor="#64748B"/>
                            <Label Text="{Binding Solicitud.TipoID}" FontSize="13" TextColor="#94A3B8"/>
                            <Label Text="{Binding Solicitud.NumeroIdentificacion}"
                                   FontSize="15" FontAttributes="Bold" TextColor="White"/>
                        </VerticalStackLayout>

                        <!-- Motivo -->
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="3">
                            <Label Text="Motivo" FontSize="11" TextColor="#64748B"/>
                            <Label Text="{Binding Solicitud.Motivo}"
                                   FontSize="14" TextColor="White"/>
                        </VerticalStackLayout>

                        <!-- Area / Empresa -->
                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="3">
                            <Label Text="Área / Empresa" FontSize="11" TextColor="#64748B"/>
                            <Label Text="{Binding Solicitud.AreaOEmpresa}"
                                   FontSize="14" TextColor="White"/>
                        </VerticalStackLayout>

                        <!-- Hora -->
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="3">
                            <Label Text="Hora solicitud" FontSize="11" TextColor="#64748B"/>
                            <Label Text="{Binding Solicitud.HoraFormateada}"
                                   FontSize="16" FontAttributes="Bold" TextColor="#2563EB"/>
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#334155"/>

                    <!-- Campo gafete -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Número de gafete *" FontSize="14"
                               FontAttributes="Bold" TextColor="#E2E8F0"/>
                        <Frame BackgroundColor="#0F172A" CornerRadius="10"
                               Padding="0" BorderColor="#334155">
                            <Entry Placeholder="Ej: G-042"
                                   PlaceholderColor="#475569"
                                   TextColor="White"
                                   Text="{Binding NumeroGafete}"
                                   Keyboard="Text"
                                   Margin="14,0"
                                   HeightRequest="52"
                                   FontSize="16"/>
                        </Frame>
                        <Label Text="Requerido para aprobar el acceso"
                               FontSize="12" TextColor="#64748B"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Botones de acción -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12"
                  IsVisible="{Binding NoEstaCargando}">

                <!-- Rechazar -->
                <Button Text="✕  Rechazar"
                        Command="{Binding RechazarCommand}"
                        BackgroundColor="#1E293B"
                        TextColor="#EF4444"
                        BorderColor="#EF4444"
                        BorderWidth="1.5"
                        CornerRadius="12"
                        HeightRequest="56"
                        FontSize="16" FontAttributes="Bold"/>

                <!-- Aprobar -->
                <Button Grid.Column="1"
                        Text="✓  Aprobar"
                        Command="{Binding AprobarCommand}"
                        BackgroundColor="#16A34A"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="56"
                        FontSize="16" FontAttributes="Bold"/>
            </Grid>

            <!-- Botón regresar -->
            <Button Text="← Regresar a solicitudes"
                    Command="{Binding RegresarCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#64748B"
                    FontSize="14"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>